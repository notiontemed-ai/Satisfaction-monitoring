    mode: "errors"
  });
}

function processSurveyResultsInternal_(options) {
  const mode = options && options.mode ? options.mode : "recent";

  const SHEET_NAME = "Опрос результат";
  const MAX_ROWS_TO_CHECK = 15;
  const SOURCE_DATE_HEADER = "date";
  const PROCESSED_AT_HEADER = "Дата обработки";
  const BITRIX_RESULT_HEADER = "bitrix";
  const WEBHOOK_URL = "https://n8n-x3.tech.temed.ru/webhook/fcc0619b-b9db-4201-b6f1-6ea2bd59be45";
  const LOG_SHEET_NAME = "Лог n8n";

  const WEBHOOK_BASE = "https://kte.bitrix24.ru/rest/72118/2l8bniiqhrtxcxl4";
  const ERROR_NOTIFY_USER_ID = "72118";
  const BITRIX_NOTIFY_PERSONAL_URL = `${WEBHOOK_BASE}/im.notify.personal.add.json`;
  const BITRIX_IM_MESSAGE_ADD_URL = `${WEBHOOK_BASE}/im.message.add.json`;
  const TASK_ADD_URL = `${WEBHOOK_BASE}/tasks.task.add.json`;
