function processSurveyResults() {
  const SHEET_NAME = "Опрос результат";
  const SOURCE_DATE_HEADER = "date";
  const PROCESSED_AT_HEADER = "Дата обработки";
  const BITRIX_RESULT_HEADER = "bitrix";
  const WEBHOOK_URL = "https://n8n-x3.tech.temed.ru/webhook/fcc0619b-b9db-4201-b6f1-6ea2bd59be45";
  const LOG_SHEET_NAME = "Лог n8n";

  const WEBHOOK_BASE = "https://kte.bitrix24.ru/rest/72118/1yg2v6i6w113bxpg";
  const TASK_ADD_URL = `${WEBHOOK_BASE}/tasks.task.add.json`;
  const DEPARTMENT_URL = `${WEBHOOK_BASE}/department.get.json`;
  const OBSERVER_ID = "2242";

  const requiredHeaders = [
    "id",
    "Дата обработки",
    "bitrix",
    "Основной сотрудник",
    "Пациент",
    "Комментарий для врача",
    "Комментарий для администратора",
    "Телефон",
    "Статус Клиента",
    "Дата установки статуса",
    "Клиника",
    "Email",
    "Дата последнего визита",
    "date",
    "Как вы оценивает общее состояние своего здоровья?",
    "Вы достигли цели лечения?",
    "Как бы вы описали свое текущее состояние?",
    "Как проходило обсуждение плана лечения?",
    "Лечение прошло так, как вы ожидали?",
    "Вам хватило общения со своим лечащим врачом?",
    "Чувствовали ли вы, что о вас заботятся на протяжении лечения?",
    "Как бы вы оценили лечение в нашей клинике?",
    "Если у вас остались вопросы, вы можете задать их главному врачу",
    "Напишите, пожалуйста, ваш вопрос и мы обязательно передадим его главному врачу клиники, в которой вы проходили лечение",
    "Как бы вам удобнее получить ответ?",
    "doc",
    "Месяц"
  ];

  const responseToHeaderMap = {
    mainEmployee: "Основной сотрудник",
    patient: "Пациент",
    doctorComment: "Комментарий для врача",
    adminComment: "Комментарий для администратора",
    phone: "Телефон",
    clientStatus: "Статус Клиента",
    statusDate: "Дата установки статуса",
    clinic: "Клиника",
    email: "Email",
    lastVisitDate: "Дата последнего визита"
  };

  const spreadsheet = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = spreadsheet.getSheetByName(SHEET_NAME);
  const logSheet = spreadsheet.getSheetByName(LOG_SHEET_NAME) || spreadsheet.insertSheet(LOG_SHEET_NAME);

  function log(message, details) {
    const detailsText = details === undefined ? "" : String(details);
    Logger.log(`${message}${detailsText ? ` | ${detailsText}` : ""}`);
    logSheet.appendRow([new Date(), message, detailsText]);
  }

  function toText(value) {
    if (value === null || value === undefined) return "";
    return typeof value === "string" ? value : String(value);
  }

  function isErrorValue(value) {
    const text = toText(value).trim();
    if (!text) return false;
    return /(^|\s)(ошибка|error)\b/i.test(text);
  }

  function isProcessedAtInExpectedFormat(value) {
    if (Object.prototype.toString.call(value) === "[object Date]") {
      return !isNaN(value.getTime());
    }
    const text = toText(value).trim();
    if (!text) return false;
    return /^\d{2}\.\d{2}\.\d{4} \d{2}:\d{2}:\d{2}$/.test(text);
  }

  function hasErrorInMappedFields(rowValues, headerIndexMap, responseMap) {
    return Object.keys(responseMap).some(responseKey => {
      const header = responseMap[responseKey];
      const value = getCellByHeader(rowValues, headerIndexMap, header, 1);
      return isErrorValue(value);
    });
  }

  function normalizePhone(value) {
    if (Array.isArray(value)) {
      return value.map(item => toText(item).trim()).filter(Boolean).join(", ");
    }
    if (value && typeof value === "object") {
      return Object.values(value).map(item => toText(item).trim()).filter(Boolean).join(", ");
    }
    return toText(value);
  }

  function normalizeClinicName(name) {
    return toText(name).trim().replace(/^Темед\s+/i, "").trim();
  }

  function addBusinessDays(date, days) {
    const result = new Date(date);
    let added = 0;
    while (added < days) {
      result.setDate(result.getDate() + 1);
      const day = result.getDay();
      if (day !== 0 && day !== 6) added += 1;
    }
    return result;
  }

  function scoreEmoji(rawScore) {
    const normalized = toText(rawScore).trim().replace(",", ".");
    const numeric = Number(normalized);
    if (!normalized || !Number.isFinite(numeric)) return "⚪";
    if (numeric < 4) return "🔴";
    if (numeric === 4) return "🟡";
    if (numeric >= 5) return "🟢";
    return "⚪";
  }

  function isLowScore(rawScore) {
    const normalized = toText(rawScore).trim().replace(",", ".");
    const numeric = Number(normalized);
    return Number.isFinite(numeric) && numeric < 4;
  }

  function buildHeaderIndexMap(headers) {
    const map = {};
    headers.forEach((header, idx) => {
      const key = toText(header).trim();
      if (!key) return;
      if (!map[key]) map[key] = [];
      map[key].push(idx);
    });
    return map;
  }

  function getCellByHeader(rowValues, headerIndexMap, header, occurrence) {
    const positions = headerIndexMap[header] || [];
    const index = positions[occurrence - 1];
    if (index === undefined) return "";
    return rowValues[index];
  }

  function ensureRequiredHeaders(headerIndexMap, required) {
    const missing = required.filter(header => !headerIndexMap[header] || headerIndexMap[header].length < 1);
    if (missing.length > 0) {
      log("Не найдены обязательные колонки", missing.join(", "));
      return false;
    }
    return true;
  }

  function fetchAllDepartments() {
    const allDepartments = [];
    let start = 0;

    while (true) {
      const url = `${DEPARTMENT_URL}?start=${start}`;
      const response = UrlFetchApp.fetch(url, { muteHttpExceptions: true });
      const status = response.getResponseCode();
      const raw = response.getContentText();

      log("HTTP статус department.get", `start=${start}; status=${status}`);

      if (status < 200 || status >= 300) {
        throw new Error(`department.get вернул HTTP ${status} (start=${start})`);
      }

      const body = JSON.parse(raw);
      const page = body.result || [];
      allDepartments.push(...page);

      if (body.next === undefined || body.next === null) {
        break;
      }

      start = Number(body.next);
      if (!Number.isFinite(start)) {
        break;
      }
    }

    return allDepartments;
  }

  function toSingleId(rawValue) {
    if (Array.isArray(rawValue)) return toText(rawValue[0]).trim();
    return toText(rawValue).trim();
  }

  function resolveResponsibleByHierarchy(startDepartment, departmentById) {
    const chain = [];
    let current = startDepartment;
    let guard = 0;

    while (current && guard < 200) {
      guard += 1;
      const headId = toSingleId(current.UF_HEAD);
      chain.push(`${current.NAME} [ID=${current.ID}, PARENT=${toText(current.PARENT).trim() || "-"}, UF_HEAD=${headId || "-"}]`);

      if (headId) {
        return {
          responsibleId: headId,
          resolvedDepartment: current,
          chain
        };
      }

      const parentId = toText(current.PARENT).trim();
      if (!parentId || parentId === "0") {
        break;
      }
      current = departmentById[parentId] || null;
    }

    return {
      responsibleId: "",
      resolvedDepartment: current || startDepartment,
      chain
    };
  }

  function formatDate(value) {
    if (!value) return "-";
    if (Object.prototype.toString.call(value) === "[object Date]" && !isNaN(value.getTime())) {
      return Utilities.formatDate(value, Session.getScriptTimeZone(), "dd.MM.yyyy HH:mm");
    }
    return toText(value).trim() || "-";
  }

  function shouldCreateTask(rowValues, headerIndexMap) {
    const careScore = getCellByHeader(
      rowValues,
      headerIndexMap,
      "Чувствовали ли вы, что о вас заботятся на протяжении лечения?",
      2
    );

    const clinicScore = getCellByHeader(
      rowValues,
      headerIndexMap,
      "Как бы вы оценили лечение в нашей клинике?",
      1
    );

    const chiefDoctorQuestionRaw = toText(
      getCellByHeader(
        rowValues,
        headerIndexMap,
        "Напишите, пожалуйста, ваш вопрос и мы обязательно передадим его главному врачу клиники, в которой вы проходили лечение",
        1
      )
    ).trim();

    return {
      hasLowScore: isLowScore(careScore) || isLowScore(clinicScore),
      hasQuestion: chiefDoctorQuestionRaw !== ""
    };
  }

  function createBitrixTaskForRow(rowValues, headerIndexMap) {
    const startAt = new Date();

    const clinic = toText(getCellByHeader(rowValues, headerIndexMap, "Клиника", 1)).trim();
    const normalizedClinic = normalizeClinicName(clinic);

    if (!clinic) {
      throw new Error("В строке пустое поле 'Клиника'");
    }

    const departments = fetchAllDepartments();
    const byId = {};
    departments.forEach(dep => {
      byId[toText(dep.ID).trim()] = dep;
    });

    const exactDepartment = departments.find(dep => toText(dep.NAME).trim() === clinic);
    const normalizedDepartment = departments.find(dep => toText(dep.NAME).trim() === normalizedClinic);
    const foundDepartment = exactDepartment || normalizedDepartment || null;

    if (!foundDepartment) {
      throw new Error(`Подразделение не найдено для клиники '${clinic}' (после нормализации: '${normalizedClinic}')`);
    }

    const hierarchy = resolveResponsibleByHierarchy(foundDepartment, byId);
    log("Цепочка fallback по PARENT", hierarchy.chain.join(" -> "));

    if (!hierarchy.responsibleId) {
      throw new Error(`Не найден UF_HEAD по всей цепочке вверх. Корневое подразделение: '${hierarchy.resolvedDepartment ? hierarchy.resolvedDepartment.NAME : foundDepartment.NAME}'`);
    }

    const deadline = addBusinessDays(startAt, 3);
    const deadlineIso = deadline.toISOString();

    const patient = toText(getCellByHeader(rowValues, headerIndexMap, "Пациент", 1)).trim();
    const clientId = toText(getCellByHeader(rowValues, headerIndexMap, "id", 1)).trim();
    const doctor = toText(getCellByHeader(rowValues, headerIndexMap, "Основной сотрудник", 1)).trim();
    const phone = toText(getCellByHeader(rowValues, headerIndexMap, "Телефон", 1)).trim();
    const email = toText(getCellByHeader(rowValues, headerIndexMap, "Email", 1)).trim();
    const surveyDate = formatDate(getCellByHeader(rowValues, headerIndexMap, "date", 1));
    const clientStatus = toText(getCellByHeader(rowValues, headerIndexMap, "Статус Клиента", 1)).trim() || "-";
    const statusDate = formatDate(getCellByHeader(rowValues, headerIndexMap, "Дата установки статуса", 1));
    const lastVisitDate = formatDate(getCellByHeader(rowValues, headerIndexMap, "Дата последнего визита", 1));
    const chiefDoctorQuestionRaw = toText(
      getCellByHeader(
        rowValues,
        headerIndexMap,
        "Напишите, пожалуйста, ваш вопрос и мы обязательно передадим его главному врачу клиники, в которой вы проходили лечение",
        1
      )
    ).trim();
    const chiefDoctorQuestion = chiefDoctorQuestionRaw || "Вопрос не указан";
    const hasQuestion = chiefDoctorQuestionRaw !== "";
    const preferredResponse = toText(getCellByHeader(rowValues, headerIndexMap, "Как бы вам удобнее получить ответ?", 1)).trim() || "-";
    const doctorComment = toText(getCellByHeader(rowValues, headerIndexMap, "Комментарий для врача", 1)).trim() || "-";
    const adminComment = toText(getCellByHeader(rowValues, headerIndexMap, "Комментарий для администратора", 1)).trim() || "-";
    const doc = toText(getCellByHeader(rowValues, headerIndexMap, "doc", 1)).trim() || "-";
    const month = toText(getCellByHeader(rowValues, headerIndexMap, "Месяц", 1)).trim() || "-";

    const questions = [
      "Как вы оценивает общее состояние своего здоровья?",
      "Вы достигли цели лечения?",
      "Как бы вы описали свое текущее состояние?",
      "Как проходило обсуждение плана лечения?",
      "Лечение прошло так, как вы ожидали?",
      "Вам хватило общения со своим лечащим врачом?",
      "Чувствовали ли вы, что о вас заботятся на протяжении лечения?"
    ];

    const qa = questions.map(questionText => {
      const answer = toText(getCellByHeader(rowValues, headerIndexMap, questionText, 1)).trim() || "-";
      const score = toText(getCellByHeader(rowValues, headerIndexMap, questionText, 2)).trim();
      return {
        questionText,
        answer,
        score: score || "-",
        emoji: scoreEmoji(score)
      };
    });

    const clinicScoreRaw = toText(getCellByHeader(rowValues, headerIndexMap, "Как бы вы оценили лечение в нашей клинике?", 1)).trim();
    qa.push({
      questionText: "Как бы вы оценили лечение в нашей клинике?",
      answer: "-",
      score: clinicScoreRaw || "-",
      emoji: scoreEmoji(clinicScoreRaw)
    });

    const careScoreRaw = toText(
      getCellByHeader(
        rowValues,
        headerIndexMap,
        "Чувствовали ли вы, что о вас заботятся на протяжении лечения?",
        2
      )
    ).trim();
    const hasLowScore = isLowScore(careScoreRaw) || isLowScore(clinicScoreRaw);

    const descriptionLines = [
      `[B]Пациент[/B]: ${patient || "-"}`,
      `[B]ID клиента[/B]: ${clientId || "-"}`,
      `[B]Клиника[/B]: ${clinic || "-"}`,
      `[B]Лечащий врач[/B]: ${doctor || "-"}`,
      `[B]Телефон[/B]: ${phone || "-"}`,
      `[B]Email[/B]: ${email || "-"}`,
      `[B]Дата опроса[/B]: ${surveyDate}`,
      `[B]Статус клиента[/B]: ${clientStatus}`,
      `[B]Дата установки статуса[/B]: ${statusDate}`,
      `[B]Дата последнего визита[/B]: ${lastVisitDate}`,
      "",
      "[B]Ответы пациента[/B]"
    ];

    qa.forEach(item => {
      descriptionLines.push(item.questionText);
      if (item.answer && item.answer !== "-") descriptionLines.push(item.answer);
      descriptionLines.push(`Оценка: ${item.emoji} ${item.score}`);
      descriptionLines.push("");
    });

    descriptionLines.push(
      "[B]Вопрос пациента[/B]",
      chiefDoctorQuestion,
      "",
      `[B]Предпочтительный способ ответа[/B]: ${preferredResponse}`,
      "",
      "[B]Комментарии[/B]",
      `[B]Комментарий для врача[/B]:`,
      `${doctorComment}`,
      `[B]Комментарий для администратора[/B]:`,
      `${adminComment}`,
      "",
      "[B]Служебный блок[/B]",
      `[B]doc[/B]: ${doc}`,
      `[B]Месяц[/B]: ${month}`
    );

    let titleSuffix = "";
    if (hasLowScore) {
      titleSuffix = "Низкая оценка";
    } else if (hasQuestion) {
      titleSuffix = "Вопрос";
    }
    const titleBase = patient || "Без имени";
    const title = titleSuffix ? `${titleBase} ${titleSuffix}` : titleBase;

    const payload = {
      fields: {
        TITLE: title,
        DESCRIPTION: descriptionLines.join("\n"),
        DESCRIPTION_IN_BBCODE: "Y",
        RESPONSIBLE_ID: hierarchy.responsibleId,
        AUDITORS: [OBSERVER_ID],
        DEADLINE: deadlineIso
      }
    };

    if (hasLowScore) {
      payload.fields.PRIORITY = "2";
      payload.fields.TASK_CONTROL = "Y";
      payload.SE_PARAMETER = [{ CODE: 3, VALUE: "Y" }];
    }

    log("Итоговый payload задачи", JSON.stringify(payload));

    const response = UrlFetchApp.fetch(TASK_ADD_URL, {
      method: "post",
      contentType: "application/json",
      payload: JSON.stringify(payload),
      muteHttpExceptions: true
    });

    const status = response.getResponseCode();
    const raw = response.getContentText();
    log("HTTP статус tasks.task.add", status);
    log("Сырой ответ Bitrix", raw);

    let body;
    try {
      body = JSON.parse(raw);
    } catch (e) {
      throw new Error(`Некорректный JSON Bitrix: ${raw}`);
    }

    const taskId = toText(body?.result?.task?.id || body?.result?.id || body?.result).trim();

    if (!(status >= 200 && status < 300) || !taskId) {
      throw new Error(`Ошибка при создании задачи: ${raw}`);
    }

    const stamp = Utilities.formatDate(new Date(), Session.getScriptTimeZone(), "yyyy-MM-dd HH:mm:ss");
    return `TASK ${taskId} ${stamp}`;
  }

  if (!sheet) {
    log(`Лист '${SHEET_NAME}' не найден`);
    return;
  }

  const lastRow = sheet.getLastRow();
  const lastColumn = sheet.getLastColumn();
  log(`Старт обработки. Лист: '${SHEET_NAME}', lastRow=${lastRow}, lastColumn=${lastColumn}`);

  if (lastRow < 2) {
    log("Нет данных для обработки (только заголовки или пустой лист)");
    return;
  }

  const headers = sheet.getRange(1, 1, 1, lastColumn).getValues()[0].map(h => toText(h).trim());
  const headerIndexMap = buildHeaderIndexMap(headers);

  if (!ensureRequiredHeaders(headerIndexMap, requiredHeaders)) {
    return;
  }

  const processedAtColumn = (headerIndexMap[PROCESSED_AT_HEADER] || [])[0] + 1;
  const bitrixColumn = (headerIndexMap[BITRIX_RESULT_HEADER] || [])[0] + 1;
  const idColumn = (headerIndexMap["id"] || [])[0] + 1;
  const sourceDateColumn = (headerIndexMap[SOURCE_DATE_HEADER] || [])[0] + 1;

  let lastDataRow = lastRow;

  if (sourceDateColumn) {
    const dateValues = sheet.getRange(2, sourceDateColumn, lastRow - 1, 1).getValues();
    lastDataRow = 1;

    for (let i = dateValues.length - 1; i >= 0; i--) {
      if (toText(dateValues[i][0]).trim() !== "") {
        lastDataRow = i + 2;
        break;
      }
    }

    if (lastDataRow === 1) {
      log(`Нет строк с заполненным '${SOURCE_DATE_HEADER}', обработка не требуется`);
      return;
    }

    log(`Последняя заполненная строка по колонке '${SOURCE_DATE_HEADER}': ${lastDataRow}`);
  }

  for (let rowNumber = lastDataRow; rowNumber >= 2; rowNumber--) {
    const rowValues = sheet.getRange(rowNumber, 1, 1, lastColumn).getValues()[0];
    const processedAtValue = sheet.getRange(rowNumber, processedAtColumn).getValue();
    const bitrixValue = sheet.getRange(rowNumber, bitrixColumn).getValue();
    const processedAtText = toText(processedAtValue).trim();
    const bitrixText = toText(bitrixValue).trim();
    const hasProcessedAtError = isErrorValue(processedAtValue) || (processedAtText !== "" && !isProcessedAtInExpectedFormat(processedAtValue));
    const hasBitrixError = isErrorValue(bitrixValue);
    const hasMappedFieldError = hasErrorInMappedFields(rowValues, headerIndexMap, responseToHeaderMap);

    const rowHasError = hasProcessedAtError || hasBitrixError || hasMappedFieldError;

    if (processedAtText !== "" && hasProcessedAtError) {
      log(`Строка ${rowNumber}: 'Дата обработки' содержит ошибку или неверный формат, повторная обработка`);
    }

    if (bitrixText !== "" && hasBitrixError) {
      log(`Строка ${rowNumber}: найдена ошибка в 'bitrix', повторная обработка`);
    }

    if (hasMappedFieldError) {
      log(`Строка ${rowNumber}: найдена ошибка в полях данных клиента, повторная обработка`);
    }

    if (!rowHasError && processedAtText !== "") {
      log(`Строка ${rowNumber}: 'Дата обработки' уже заполнена без ошибок, пропуск`);
      continue;
    }

    if (!rowHasError && bitrixText !== "") {
      log(`Строка ${rowNumber}: колонка 'bitrix' уже заполнена без ошибок, пропуск`);
      continue;
    }

    const clientId = toText(sheet.getRange(rowNumber, idColumn).getValue()).trim();
    if (!clientId) {
      const errorText = "Ошибка: пустой id";
      sheet.getRange(rowNumber, processedAtColumn).setValue(errorText);
      sheet.getRange(rowNumber, bitrixColumn).setValue(errorText);
      log(`Строка ${rowNumber}: ${errorText}`);
      continue;
    }

    const payload = { clientId };
    log(`Строка ${rowNumber}: отправка webhook`, JSON.stringify(payload));

    try {
      const response = UrlFetchApp.fetch(WEBHOOK_URL, {
        method: "post",
        contentType: "application/json",
        payload: JSON.stringify(payload),
        muteHttpExceptions: true
      });

      const statusCode = response.getResponseCode();
      const responseText = toText(response.getContentText()).trim();
      log(`Строка ${rowNumber}: HTTP ${statusCode}`, responseText || "<пустой ответ>");

      if (!(statusCode >= 200 && statusCode < 300)) {
        const errorText = `Ошибка HTTP ${statusCode}`;
        sheet.getRange(rowNumber, processedAtColumn).setValue(errorText);
        sheet.getRange(rowNumber, bitrixColumn).setValue(errorText);
        log(`Строка ${rowNumber}: ${errorText}`);
        continue;
      }

      if (!responseText) {
        const errorText = "Ошибка: пустой ответ webhook";
        sheet.getRange(rowNumber, processedAtColumn).setValue(errorText);
        sheet.getRange(rowNumber, bitrixColumn).setValue(errorText);
        log(`Строка ${rowNumber}: ${errorText}`);
        continue;
      }

      let body;
      try {
        body = JSON.parse(responseText);
      } catch (parseError) {
        const errorText = `Ошибка: некорректный JSON (${parseError})`;
        sheet.getRange(rowNumber, processedAtColumn).setValue(errorText);
        sheet.getRange(rowNumber, bitrixColumn).setValue(errorText);
        log(`Строка ${rowNumber}: ${errorText}`);
        continue;
      }

      if (!body || typeof body !== "object") {
        const errorText = "Ошибка: webhook вернул некорректный объект";
        sheet.getRange(rowNumber, processedAtColumn).setValue(errorText);
        sheet.getRange(rowNumber, bitrixColumn).setValue(errorText);
        log(`Строка ${rowNumber}: ${errorText}`);
        continue;
      }

      Object.keys(responseToHeaderMap).forEach(responseKey => {
        const targetHeader = responseToHeaderMap[responseKey];
        const targetColumn = ((headerIndexMap[targetHeader] || [])[0] || 0) + 1;
        const rawValue = body[responseKey];
        const value = responseKey === "phone" ? normalizePhone(rawValue) : toText(rawValue);
        sheet.getRange(rowNumber, targetColumn).setValue(value);
      });

      const updatedRowValues = sheet.getRange(rowNumber, 1, 1, lastColumn).getValues()[0];
      const taskDecision = shouldCreateTask(updatedRowValues, headerIndexMap);

      if (taskDecision.hasLowScore || taskDecision.hasQuestion) {
        try {
          const taskResult = createBitrixTaskForRow(updatedRowValues, headerIndexMap);
          sheet.getRange(rowNumber, bitrixColumn).setValue(taskResult);
          log(`Строка ${rowNumber}: задача создана`, taskResult);
        } catch (taskError) {
          const taskErrorText = `Ошибка Bitrix: ${taskError}`;
          sheet.getRange(rowNumber, bitrixColumn).setValue(taskErrorText);
          log(`Строка ${rowNumber}: ${taskErrorText}`);
        }
      } else {
        sheet.getRange(rowNumber, bitrixColumn).setValue("не требуется");
        log(`Строка ${rowNumber}: задача не требуется`);
      }

      const processedStamp = Utilities.formatDate(new Date(), Session.getScriptTimeZone(), "dd.MM.yyyy HH:mm:ss");
      sheet.getRange(rowNumber, processedAtColumn).setValue(processedStamp);
      log(`Строка ${rowNumber}: данные записаны, timestamp установлен`);
    } catch (error) {
      const errorText = `Ошибка запроса: ${error}`;
      sheet.getRange(rowNumber, processedAtColumn).setValue(errorText);
      sheet.getRange(rowNumber, bitrixColumn).setValue(errorText);
      log(`Строка ${rowNumber}: ${errorText}`);
    }
  }

  log("Обработка завершена");
}

function onOpen() {
  SpreadsheetApp.getUi()
    .createMenu("Интеграции")
    .addItem("Обработать", "processSurveyResults")
    .addToUi();
}
