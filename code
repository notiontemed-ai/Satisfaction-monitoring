  if (!hierarchy.responsibleId) {
    log("Ошибка", `Не найден UF_HEAD по всей цепочке вверх. Корневое подразделение: '${hierarchy.resolvedDepartment ? hierarchy.resolvedDepartment.NAME : foundDepartment.NAME}'`);
